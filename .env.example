APP_NAME="Code Review"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://codereview.test
# In production set APP_URL=https://app.fullcodereview.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# === Database (PostgreSQL — create the DB in TablePlus first) ===
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=codereview
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

# === Mail (Resend) ===
# Get a key at https://resend.com/api-keys after verifying your domain.
# Use "log" locally if you don't want to send real emails during development.
MAIL_MAILER=resend
RESEND_KEY=
MAIL_FROM_ADDRESS="hello@fullcodereview.com"
MAIL_FROM_NAME="Full Code Review"

# === Stripe ===
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_CENTS=3000
STRIPE_PRODUCT_NAME="Code Review"
STRIPE_SUCCESS_URL="${APP_URL}/?session_id={CHECKOUT_SESSION_ID}"
STRIPE_CANCEL_URL="${APP_URL}/?canceled=1"

# === GitHub OAuth (for scanning private repos) ===
# Create OAuth app: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/api/github/callback"

# === Google OAuth (Sign in with Google) ===
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must exactly match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/auth/google/callback"

# === Anthropic (Claude) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

VITE_APP_NAME="${APP_NAME}"
